<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>SALIX AI</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>salix_ai</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<false/>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Permissions used by SALIX AI v1.2.0 -->
	<key>NSCameraUsageDescription</key>
	<string>SALIX precisa da câmera pra analisar imagens que você capturar</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>SALIX precisa acessar fotos pra analisar imagens</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>SALIX pode salvar imagens geradas na sua galeria</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>SALIX usa o microfone para entrada de voz (STT)</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>SALIX usa reconhecimento de fala para converter sua voz em texto</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>SALIX precisa acessar documentos para envio de PDFs e planilhas</string>

	<!-- Onda 4 C9/C10/AU4: localização (geofencing) + contatos -->
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>SALIX usa sua localização para rotinas baseadas em lugar (chegada/saída)</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>SALIX precisa de localização sempre para disparar rotinas mesmo com app fechado</string>
	<key>NSLocationAlwaysUsageDescription</key>
	<string>SALIX precisa de localização sempre para geofencing em background</string>
	<key>NSContactsUsageDescription</key>
	<string>SALIX usa contatos para fazer chamadas e enviar mensagens pelo nome</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>fetch</string>
	</array>

	<!-- Onda 4 C10: deep links pra apps externos. iOS exige declaração explícita -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>sms</string>
		<string>mailto</string>
		<string>whatsapp</string>
		<string>youtube</string>
		<string>spotify</string>
		<string>waze</string>
		<string>uber</string>
		<string>taxis99</string>
		<string>ifood</string>
		<string>meli</string>
		<string>instagram</string>
		<string>tg</string>
		<string>telegram</string>
		<string>comgooglemaps</string>
	</array>
</dict>
</plist>
